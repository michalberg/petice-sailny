---
import config from "@/config/petition.json";
const { petition } = config;
---

<article id="text-petice" class="rounded-2xl border-l-[6px] border-[#ffa6d1] bg-white p-8 shadow-sm">
  <h3 class="text-text-dark">{petition.heading}</h3>
  <p class="mt-4 italic text-text/60">{petition.addressee}</p>
  {petition.paragraphs.map((p) => (
    <p class="mt-3 text-text" set:html={p} />
  ))}
  {petition.demands.map((d) => (
    <p class="mt-2 pl-6 text-text" set:html={d} />
  ))}
  <p class="mt-4 text-text" set:html={petition.closing} />
  <p class="mt-4 text-sm text-text/50">{petition.place_date}</p>
  <p class="mt-3 font-semibold text-text-dark">{petition.committee_label}</p>
  <ul class="mt-2 space-y-1">
    {petition.committee.map((m) => (
      <li class="text-text">
        <strong class="text-text-dark">{m.name}</strong>, {m.role}
      </li>
    ))}
  </ul>
</article>
