---
import { readdirSync } from "fs";
import { join } from "path";

const dir = join(process.cwd(), "public/fonty");
const files = readdirSync(dir).sort();

// Seskupit soubory podle základního názvu fontu
const fontMap = new Map();
const priority = ["woff2", "otf", "woff", "ttf", "eot"];

for (const file of files) {
  const match = file.match(/^(.+?)\.(woff2?|ttf|eot|otf)$/);
  if (!match) continue;
  const stem = match[1];
  const ext = match[2];

  // Přeskočit duplikáty jako "TuskerGrotesk-6700Bold-2"
  if (/-\d+$/.test(stem)) continue;

  if (!fontMap.has(stem)) fontMap.set(stem, {});
  const existing = fontMap.get(stem);
  if (!existing[ext]) existing[ext] = file;
}

// Pro každý font vybrat nejlepší formát pro @font-face
const fonts = [];
for (const [stem, exts] of fontMap.entries()) {
  let file = null;
  let format = null;
  for (const ext of priority) {
    if (exts[ext]) {
      file = exts[ext];
      format = ext === "otf" ? "opentype" : ext === "ttf" ? "truetype" : ext;
      break;
    }
  }
  if (!file) continue;

  // Zobrazitelný název
  const display = stem
    .replace(/([a-z])([A-Z])/g, "$1 $2")
    .replace(/-/g, " ")
    .replace(/(\d+)/g, " $1 ")
    .replace(/\s+/g, " ")
    .trim();

  fonts.push({ stem, file, format, display, exts });
}

const fontFaceCSS = fonts.map(f =>
  `@font-face { font-family: '${f.stem}'; src: url('/fonty/${f.file}') format('${f.format}'); }`
).join("\n");
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zelení — Firemní fonty</title>
    <style set:html={fontFaceCSS}></style>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, sans-serif; background: #f5f5f0; color: #111; padding: 2rem 1rem; }
      .container { max-width: 860px; margin: 0 auto; }
      header { margin-bottom: 2.5rem; }
      header h1 { font-size: 1.75rem; font-weight: 700; margin-bottom: 0.25rem; }
      header p { color: #666; font-size: 0.9rem; }
      .font-card {
        background: white; border-radius: 10px;
        padding: 1.25rem 1.5rem; margin-bottom: 0.75rem;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
      }
      .font-preview {
        font-size: 1.6rem; line-height: 1.2; flex: 1;
        min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis;
      }
      .font-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 0.35rem; flex-shrink: 0; }
      .font-name { font-size: 0.7rem; color: #999; text-align: right; }
      .download-links { display: flex; gap: 0.3rem; flex-wrap: wrap; justify-content: flex-end; }
      .download-links a {
        background: #0bd26f; color: #000; font-size: 0.65rem; font-weight: 700;
        padding: 0.15rem 0.45rem; border-radius: 4px; text-decoration: none;
        letter-spacing: 0.04em; text-transform: uppercase;
      }
      .download-links a:hover { background: #09b860; }
      @media (max-width: 500px) {
        .font-card { flex-direction: column; align-items: flex-start; }
        .font-meta { align-items: flex-start; }
        .download-links { justify-content: flex-start; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <h1>Zelení — Firemní fonty</h1>
        <p>{fonts.length} fontů · klikněte na formát pro stažení</p>
      </header>

      {fonts.map((font) => (
        <div class="font-card">
          <div class="font-preview" style={`font-family: '${font.stem}'`}>
            {font.display}
          </div>
          <div class="font-meta">
            <span class="font-name">{font.stem}</span>
            <div class="download-links">
              {Object.entries(font.exts).map(([ext, file]) => (
                <a href={`/fonty/${file}`} download>{ext}</a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </body>
</html>
