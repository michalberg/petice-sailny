<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zelení — Firemní fonty</title>
    <style>
      {fonts.filter(f => f.cssName).map(f =>
        `@font-face { font-family: '${f.cssName}'; src: ${f.src}; }`
      ).join('\n')}

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: system-ui, sans-serif;
        background: #f5f5f0;
        color: #111;
        padding: 2rem 1rem;
      }

      .container {
        max-width: 800px;
        margin: 0 auto;
      }

      header {
        margin-bottom: 3rem;
      }

      header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
      }

      header p {
        color: #666;
        font-size: 0.95rem;
      }

      .font-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .font-preview {
        font-size: 1.75rem;
        line-height: 1.2;
        flex: 1;
        min-width: 0;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
      }

      .font-meta {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.4rem;
        flex-shrink: 0;
      }

      .font-name {
        font-size: 0.75rem;
        color: #888;
        text-align: right;
      }

      .download-links {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .download-links a {
        display: inline-block;
        background: #0bd26f;
        color: #000;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        text-decoration: none;
        letter-spacing: 0.05em;
      }

      .download-links a:hover {
        background: #09b860;
      }

      @media (max-width: 500px) {
        .font-card { flex-direction: column; align-items: flex-start; }
        .font-meta { align-items: flex-start; }
        .download-links { justify-content: flex-start; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <h1>Zelení — Firemní fonty</h1>
        <p>Klikněte na formát pro stažení souboru.</p>
      </header>

      {fonts.map((font) => (
        <div class="font-card">
          <div
            class="font-preview"
            style={font.cssName ? `font-family: '${font.cssName}'` : ""}
          >
            {font.preview}
          </div>
          <div class="font-meta">
            <span class="font-name">{font.name}</span>
            <div class="download-links">
              {font.files.map((f) => (
                <a href={f.url} download>{f.label}</a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </body>
</html>
